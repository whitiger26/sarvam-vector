# Required: Groq API key (powers all LLM calls).
# Get a key at https://console.groq.com — free tier available with no credit card.
GROQ_API_KEY=gsk_...

# Optional: Sarvam API key for voice and translation.
# When present on the server, all voice features work for every user
# without anyone needing to enter their own key. The browser never sees it.
# Get a key at https://www.sarvam.ai
SARVAM_API_KEY=
